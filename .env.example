# ─────────────────────────────────────────────────────────────────────────────
# FarmEasy Backend — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.
# On Railway: add these in the service Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# On Railway: set to ${{Postgres.DATABASE_URL}} (Railway auto-injects this)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Redis ─────────────────────────────────────────────────────────────────────
# On Railway: set to ${{Redis.REDIS_URL}}
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-very-long-random-secret-at-least-64-chars"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_DAYS=30

# ── Field-level Encryption (PII: Aadhaar, PAN, bank account) ──────────────────
# REQUIRED in production. Generate: openssl rand -hex 32
FIELD_ENCRYPTION_KEY="64-char-hex-string"

# ── OTP (MSG91) ───────────────────────────────────────────────────────────────
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_TEMPLATE_ID="your-msg91-template-id"
MSG91_SENDER_ID="FRMESY"
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Google Gemini (FREE: 15 RPM / 1M tokens/day) ─────────────────────────────
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"

# ── Groq (FREE tier: 30 RPM / 14,400 RPD) ────────────────────────────────────
# Get key: https://console.groq.com
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="llama-3.3-70b-versatile"

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# ── Python AI Service (CropGuard) ─────────────────────────────────────────────
# On Railway: use the private domain, e.g. http://ai-service.railway.internal:8000
# Locally: http://localhost:8001
AI_BACKEND_URL="http://localhost:8001"

# ── Sarvam AI (Indian multilingual) ──────────────────────────────────────────
# Get key: https://dashboard.sarvam.ai
SARVAM_API_KEY="your-sarvam-api-key"

# ── Market Data (data.gov.in — FREE) ──────────────────────────────────────────
DATA_GOV_API_KEY="your-data-gov-api-key"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins (mobile apps don't need this)
# Example: https://admin.farmeasy.app,https://farmeasy.app
ALLOWED_ORIGINS=""

# ── Rate Limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
OTP_RATE_LIMIT_MAX=5
