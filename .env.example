# ─────────────────────────────────────────────────────────────────────────────
# CropSetu Farmer App — Environment Variables (template)
# ─────────────────────────────────────────────────────────────────────────────
# React Native apps don't use a runtime .env by default — Expo bakes these
# into the JS bundle at build time via `EXPO_PUBLIC_*` prefix.
# Anything in the compiled APK is extractable — never put real secrets here.
# For CI / EAS Build, set these under "EAS Secrets" in the Expo dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# EAS project ID (from app.json → expo.extra.eas.projectId).
# Farmer app: 9681090a-1af6-4835-8a2f-7b0ea7681b9a
EAS_PROJECT_ID=9681090a-1af6-4835-8a2f-7b0ea7681b9a

# Public API endpoint (overrides src/constants/config.js).
# Dev:  http://10.0.2.2:3001/api/v1         (Android emulator)
# Prod: https://<your-railway-domain>/api/v1
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_SOCKET_URL=

# Sentry DSN for crash reporting (optional).
EXPO_PUBLIC_SENTRY_DSN=

# Play Store service account JSON path (for EAS submit).
# Download from Play Console → API access. Path is relative to repo root.
ANDROID_SERVICE_ACCOUNT_JSON=./play-store-credentials.json
