# CropGuard Agentic AI — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── Anthropic (Claude API) — used by all 5 agentic pipeline agents ─────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Groq (primary chat LLM — fast, free tier available) ───────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Gemini (chat fallback + vision fallback) ────────────────────────────
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Optional: override default model names ─────────────────────────────────────
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# GEMINI_CHAT_MODEL=gemini-2.0-flash

# ── Service bind address ───────────────────────────────────────────────────────
CROPGUARD_HOST=0.0.0.0
CROPGUARD_PORT=8001
