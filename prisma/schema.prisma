// ─────────────────────────────────────────────────────────────────────────────
// FarmEasy — Prisma Schema
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  FARMER
  VERIFIED_FARMER
  LABOUR_PROVIDER
  MACHINERY_OWNER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ListingStatus {
  ACTIVE
  SOLD
  RENTED
  INACTIVE
}

enum AnimalGender {
  MALE
  FEMALE
}

enum NotificationType {
  ORDER_UPDATE
  BOOKING_UPDATE
  NEW_MESSAGE
  NEW_COMMENT
  POST_LIKE
  SYSTEM
}

enum PostScope {
  ALL
  DISTRICT
  CITY
}

enum GroupRole {
  ADMIN
  MEMBER
}

// ── Users & Auth ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  name          String?
  avatar        String?   // Cloudinary URL
  statusQuote   String?   // WhatsApp-like status/quote
  role          Role      @default(FARMER)
  language      String    @default("en") // en | hi | mr
  isActive      Boolean   @default(true)

  // Location (for district-level filtering)
  pincode       String?
  district      String?
  city          String?
  state         String?   @default("Maharashtra")

  isOnline      Boolean   @default(false)
  lastSeenAt    DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  farmDetail      FarmDetail?
  otpSessions     OtpSession[]
  refreshTokens   RefreshToken[]
  pushTokens      PushToken[]

  // AgriStore
  orders          Order[]
  cartItems       CartItem[]
  reviews         Review[]
  sellerProducts  Product[]       @relation("SellerProducts")

  // Animal Trade
  animalListings  AnimalListing[]
  chatsAsSeller   Chat[]          @relation("SellerChats")
  chatsAsBuyer    Chat[]          @relation("BuyerChats")

  // Rent
  machineryListings MachineryListing[]
  labourListings    LabourListing[]
  bookings          Booking[]

  // Community
  posts           Post[]
  postLikes       PostLike[]
  postBookmarks   PostBookmark[]
  comments        Comment[]
  commentLikes    CommentLike[]

  // Groups & Messaging
  groupsCreated   Group[]         @relation("GroupsCreated")
  groupMembers    GroupMember[]
  groupMessages   GroupMessage[]  @relation("GroupMessagesSent")
  dmsSent         DirectMessage[] @relation("DMsSent")
  dmsReceived     DirectMessage[] @relation("DMsReceived")

  notifications   Notification[]

  @@map("users")
}

model FarmDetail {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  village      String?
  district     String?
  state        String?
  pincode      String?
  landAcres    Float?
  cropTypes    String[]
  soilType     String?
  irrigationType String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("farm_details")
}

model OtpSession {
  id          String   @id @default(uuid())
  phone       String
  otp         String
  attempts    Int      @default(0)
  verified    Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@map("otp_sessions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model PushToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String
  createdAt DateTime @default(now())

  @@map("push_tokens")
}

// ── AgriStore ─────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  nameHi      String?
  nameMr      String?
  icon        String?
  color       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  products    Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  // Seller (null = platform / admin seeded product)
  sellerId    String?
  seller      User?    @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: SetNull)

  name        String
  nameHi      String?
  nameMr      String?
  description String?
  price       Float
  mrp         Float?
  unit        String   @default("kg")
  stock       Int      @default(0)
  images      String[]
  tags        String[]
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)

  // Location-based visibility
  district    String?  // If null → visible to all; if set → only that district
  state       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]

  @@index([categoryId])
  @@index([sellerId])
  @@index([district])
  @@map("products")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("cart_items")
}

model Order {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        OrderStatus @default(PENDING)
  totalAmount   Float
  deliveryAddress Json
  paymentMethod String      @default("cod")
  paymentStatus String      @default("pending")
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items         OrderItem[]

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  totalPrice Float

  @@map("order_items")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("reviews")
}

// ── Animal Trade ──────────────────────────────────────────────────────────────

model AnimalListing {
  id             String        @id @default(uuid())
  sellerId       String
  seller         User          @relation(fields: [sellerId], references: [id])
  animal         String
  breed          String
  age            String
  gender         AnimalGender
  weight         String
  price          Float
  milkYield      String?
  description    String?
  images         String[]
  tags           String[]
  verified       Boolean       @default(false)
  status         ListingStatus @default(ACTIVE)
  sellerLocation String
  viewCount      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  chats          Chat[]

  @@index([sellerId])
  @@index([animal])
  @@index([status])
  @@map("animal_listings")
}

model Chat {
  id        String   @id @default(uuid())
  listingId String
  listing   AnimalListing @relation(fields: [listingId], references: [id])
  sellerId  String
  seller    User     @relation("SellerChats", fields: [sellerId], references: [id])
  buyerId   String
  buyer     User     @relation("BuyerChats", fields: [buyerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ChatMessage[]

  @@unique([listingId, buyerId])
  @@map("chats")
}

model ChatMessage {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  text      String?
  imageUrl  String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([chatId])
  @@map("chat_messages")
}

// ── Rent ──────────────────────────────────────────────────────────────────────

model MachineryListing {
  id           String        @id @default(uuid())
  ownerId      String
  owner        User          @relation(fields: [ownerId], references: [id])
  name         String
  category     String
  description  String?
  pricePerDay  Float
  pricePerHour Float?
  images       String[]
  location     String
  district     String
  state        String
  available    Boolean       @default(true)
  status       ListingStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  bookings     Booking[]

  @@index([ownerId])
  @@index([district])
  @@map("machinery_listings")
}

model LabourListing {
  id           String        @id @default(uuid())
  providerId   String
  provider     User          @relation(fields: [providerId], references: [id])
  name         String
  skills       String[]
  pricePerDay  Float
  groupSize    Int           @default(1)
  experience   String?
  languages    String[]
  location     String
  district     String
  state        String
  available    Boolean       @default(true)
  status       ListingStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  bookings     Booking[]

  @@index([providerId])
  @@index([district])
  @@map("labour_listings")
}

model Booking {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  machineryListingId String?
  machineryListing   MachineryListing? @relation(fields: [machineryListingId], references: [id])
  labourListingId   String?
  labourListing     LabourListing? @relation(fields: [labourListingId], references: [id])
  startDate         DateTime
  endDate           DateTime
  days              Int
  totalAmount       Float
  status            BookingStatus @default(PENDING)
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@map("bookings")
}

// ── Community Posts ───────────────────────────────────────────────────────────

model Post {
  id           String    @id @default(uuid())
  authorId     String
  author       User      @relation(fields: [authorId], references: [id])
  category     String
  title        String
  description  String
  images       String[]
  tags         String[]
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  viewCount    Int       @default(0)
  isPinned     Boolean   @default(false)

  // Location scope
  scope        PostScope @default(ALL)
  district     String?   // set when scope = DISTRICT or CITY
  city         String?   // set when scope = CITY

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  likes        PostLike[]
  bookmarks    PostBookmark[]
  comments     Comment[]

  @@index([authorId])
  @@index([category])
  @@index([district])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("post_likes")
}

model PostBookmark {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("post_bookmarks")
}

model Comment {
  id        String    @id @default(uuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  parentId  String?
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  text      String
  likeCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  likes     CommentLike[]

  @@index([postId])
  @@map("comments")
}

model CommentLike {
  id        String  @id @default(uuid())
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_likes")
}

// ── Community Groups (WhatsApp-like) ──────────────────────────────────────────

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  avatar      String?  // Cloudinary URL
  createdById String
  createdBy   User     @relation("GroupsCreated", fields: [createdById], references: [id])

  // Location scope (optional)
  district    String?
  city        String?
  isPublic    Boolean  @default(true)

  memberCount Int      @default(1)
  lastMessage String?
  lastMessageAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]
  messages    GroupMessage[]

  @@index([district])
  @@map("groups")
}

model GroupMember {
  id        String    @id @default(uuid())
  groupId   String
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      GroupRole @default(MEMBER)
  joinedAt  DateTime  @default(now())

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

model GroupMessage {
  id        String   @id @default(uuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("GroupMessagesSent", fields: [senderId], references: [id])
  text      String?
  imageUrl  String?
  type      String   @default("text") // text | image | system
  createdAt DateTime @default(now())

  @@index([groupId])
  @@index([senderId])
  @@map("group_messages")
}

// ── Direct Messages ───────────────────────────────────────────────────────────

model DirectMessage {
  id           String   @id @default(uuid())
  senderId     String
  sender       User     @relation("DMsSent", fields: [senderId], references: [id])
  receiverId   String
  receiver     User     @relation("DMsReceived", fields: [receiverId], references: [id])
  text         String?
  imageUrl     String?
  readAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
  @@map("direct_messages")
}

// ── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@map("notifications")
}
