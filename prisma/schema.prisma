// ─────────────────────────────────────────────────────────────────────────────
// FarmEasy — Prisma Schema
// Designed for 10 lakh+ concurrent users:
//   • All FK columns indexed
//   • Denormalised sellerId on OrderItem for O(1) seller queries
//   • Composite indexes for every paginated list pattern
//   • Separate SellerProfile table isolates sensitive bank / KYC data
//   • CropDiseaseReport persists every AI analysis
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  FARMER
  SELLER
  VERIFIED_FARMER
  LABOUR_PROVIDER
  MACHINERY_OWNER
  ADMIN
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ListingStatus {
  ACTIVE
  SOLD
  RENTED
  INACTIVE
}

enum AnimalGender {
  MALE
  FEMALE
}

enum NotificationType {
  ORDER_UPDATE
  BOOKING_UPDATE
  NEW_MESSAGE
  NEW_COMMENT
  POST_LIKE
  SYSTEM
}

enum PostScope {
  ALL
  DISTRICT
  CITY
}

enum GroupRole {
  ADMIN
  MEMBER
}

// ── Users & Auth ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  name          String?
  avatar        String?   // Cloudinary URL
  statusQuote   String?
  role          Role      @default(FARMER)
  language      String    @default("en") // en | hi | mr
  isActive      Boolean   @default(true)

  // Location
  pincode       String?
  district      String?
  taluka        String?
  village       String?
  city          String?
  state         String?   @default("Maharashtra")

  // Seller identity fields
  businessType  String?   // individual_farmer | farmer_group | fpc | cooperative | agri_business
  gstNumber     String?
  gstOptOut     Boolean   @default(false)

  // KYC / account status (safe, non-sensitive status fields)
  kycStatus     KycStatus @default(PENDING)

  // Computed profile completeness (0-100), updated on every profile save
  profileCompletion Int   @default(0)

  isOnline      Boolean   @default(false)
  lastSeenAt    DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sellerProfile   SellerProfile?
  farmDetail      FarmDetail?
  otpSessions     OtpSession[]
  refreshTokens   RefreshToken[]
  pushTokens      PushToken[]

  // AgriStore
  orders          Order[]
  cartItems       CartItem[]
  reviews         Review[]
  sellerProducts  Product[]         @relation("SellerProducts")
  savedAddresses  SavedAddress[]

  // Animal Trade
  animalListings  AnimalListing[]
  chatsAsSeller   Chat[]            @relation("SellerChats")
  chatsAsBuyer    Chat[]            @relation("BuyerChats")

  // Rent
  machineryListings MachineryListing[]
  labourListings    LabourListing[]
  bookings          Booking[]

  // Community
  posts           Post[]
  postLikes       PostLike[]
  postBookmarks   PostBookmark[]
  comments        Comment[]
  commentLikes    CommentLike[]

  // Groups & Messaging
  groupsCreated   Group[]           @relation("GroupsCreated")
  groupMembers    GroupMember[]
  groupMessages   GroupMessage[]    @relation("GroupMessagesSent")
  dmsSent         DirectMessage[]   @relation("DMsSent")
  dmsReceived     DirectMessage[]   @relation("DMsReceived")

  notifications       Notification[]
  cropDiseaseReports  CropDiseaseReport[]

  // FarmMind AI
  aiConversations     AIConversation[]
  plannerTasks        PlannerTask[]
  diseaseFeedbacks    DiseaseFeedback[]
  schemeApplications  SchemeApplication[]
  voiceSessions       VoiceSession[]
  doctorReviews       DoctorReview[]
  aiUsage             AIUsage[]

  // New AI services
  priceAlerts         PriceAlert[]
  soilHealthRecords   SoilHealthRecord[]
  cropCalendars       CropCalendar[]
  irrigationLogs      IrrigationLog[]

  @@index([phone])
  @@index([district])
  @@index([kycStatus])
  @@map("users")
}

// ── Seller Profile (sensitive bank + KYC data — isolated table) ───────────────
// Storing bank/KYC separately:
//   • Easier to encrypt/audit this table independently
//   • User table stays lean for the hot read path (auth, listing queries)

model SellerProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Bank account
  bankHolderName    String?
  bankName          String?
  bankAccountNumber String?   // store encrypted in production
  bankIfsc          String?

  // KYC documents
  aadharNumber      String?   // store encrypted in production
  panNumber         String?
  kycDocumentUrls   String[]  // Cloudinary URLs of uploaded doc images

  // Verification workflow
  kycVerifiedAt     DateTime?
  kycRejectedReason String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("seller_profiles")
}

model FarmDetail {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  village        String?
  district       String?
  state          String?
  pincode        String?
  landAcres      Float?
  cropTypes      String[]
  soilType       String?
  irrigationType String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("farm_details")
}

model OtpSession {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_sessions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PushToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_tokens")
}

// ── AgriStore ─────────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  nameHi    String?
  nameMr    String?
  icon      String?
  color     String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  products  Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  // Seller (null = platform / admin seeded product)
  sellerId    String?
  seller      User?    @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: SetNull)

  name        String
  nameHi      String?
  nameMr      String?
  description String?
  price       Float
  mrp         Float?
  unit        String   @default("kg")
  stock       Int      @default(0)
  minOrderQty Int      @default(1)
  images      String[]
  tags        String[]
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  viewCount   Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)

  // Location — granular: district → taluka → village
  district    String?
  taluka      String?
  village     String?
  state       String?

  // Subcategory within the main category (e.g. "Cereal & Grain Seeds" inside "Seeds & Planting Material")
  subcategory String?

  // Selling reach: village | taluka | district | state | all_india
  sellScope   String   @default("district")

  // Harvest / availability
  harvestDate String?

  // Product detail — shown on product page
  brand           String?
  manufacturer    String?
  countryOfOrigin String?
  highlights      String[]          // bullet-point highlights list
  specifications  Json?             // { "key": "value", ... } free-form spec map

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]

  @@index([categoryId])
  @@index([sellerId])
  @@index([district])
  @@index([taluka])
  @@index([isActive, isFeatured])
  @@index([isActive, rating])
  @@index([createdAt])
  @@map("products")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
  @@map("cart_items")
}

// Saved delivery addresses — users can store multiple addresses for fast re-use at checkout
model SavedAddress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   @default("HOME")  // HOME | OFFICE | OTHER
  name      String
  phone     String
  flat      String
  street    String
  city      String
  state     String
  pincode   String
  landmark  String?

  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
  @@map("saved_addresses")
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          OrderStatus @default(PENDING)
  totalAmount     Float
  deliveryAddress Json
  paymentMethod   String      @default("cod")
  paymentStatus   String      @default("pending")
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

// sellerId is DENORMALISED here for O(1) seller-order lookups.
// Without it every seller orders query needs a join through products.
// At 10L users with thousands of daily orders this join becomes a bottleneck.
model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  sellerId   String? // denormalised FK — set on order creation
  quantity   Int
  unitPrice  Float
  totalPrice Float

  @@index([orderId])
  @@index([sellerId])
  @@index([sellerId, orderId])
  @@map("order_items")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
  @@map("reviews")
}

// ── Animal Trade ──────────────────────────────────────────────────────────────

model AnimalListing {
  id             String        @id @default(uuid())
  sellerId       String
  seller         User          @relation(fields: [sellerId], references: [id])
  animal         String
  breed          String
  age            String
  gender         AnimalGender
  weight         String
  price          Float
  milkYield      String?
  description    String?
  images         String[]
  tags           String[]
  verified       Boolean       @default(false)
  status         ListingStatus @default(ACTIVE)
  sellerLocation String
  lat            Float?
  lng            Float?
  viewCount      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  chats          Chat[]

  @@index([sellerId])
  @@index([animal])
  @@index([status])
  @@index([createdAt])
  @@map("animal_listings")
}

model Chat {
  id        String        @id @default(uuid())
  listingId String
  listing   AnimalListing @relation(fields: [listingId], references: [id])
  sellerId  String
  seller    User          @relation("SellerChats", fields: [sellerId], references: [id])
  buyerId   String
  buyer     User          @relation("BuyerChats", fields: [buyerId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages  ChatMessage[]

  @@unique([listingId, buyerId])
  @@index([sellerId])
  @@index([buyerId])
  @@map("chats")
}

model ChatMessage {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  text      String?
  imageUrl  String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([chatId, createdAt])
  @@map("chat_messages")
}

// ── Rent ──────────────────────────────────────────────────────────────────────

model MachineryListing {
  id           String        @id @default(uuid())
  ownerId      String
  owner        User          @relation(fields: [ownerId], references: [id])

  // Core info
  name         String        // e.g. "Mahindra 575 DI Tractor"
  category     String        // tractor|harvester|sprayer|rotavator|thresher|transplanter|truck|tempo|other
  description  String?
  brand        String?
  ageYears     Float?        // age of equipment in years
  mileageHours Int?          // total hours of use
  horsePower   String?       // e.g. "47 HP"
  fuelType     String?       // diesel|petrol|electric
  features     String[]      // e.g. ["4WD","GPS","AC Cabin"]

  // Pricing
  pricePerHour Float?
  pricePerDay  Float
  pricePerAcre Float?

  // Media
  images       String[]
  videos       String[]      // Cloudinary video URLs

  // Location
  location     String
  district     String
  state        String
  lat          Float?        // GPS latitude  (auto-filled from device on listing creation)
  lng          Float?        // GPS longitude

  // Availability window
  availableFrom DateTime?
  availableTo   DateTime?

  // Owner contact (denormalised for perf)
  ownerName    String?
  ownerPhone   String?

  // Stats
  rating       Float         @default(0)
  ratingCount  Int           @default(0)

  available    Boolean       @default(true)
  status       ListingStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  bookings     Booking[]

  @@index([ownerId])
  @@index([category])
  @@index([district])
  @@index([status])
  @@index([status, category])
  @@index([lat, lng])
  @@map("machinery_listings")
}

model LabourListing {
  id           String        @id @default(uuid())
  providerId   String
  provider     User          @relation(fields: [providerId], references: [id])

  name         String        // display name (individual name or group name)
  leader       String?       // contact/leader name
  groupName    String?       // formal group name
  skills       String[]
  experience   String?
  description  String?
  languages    String[]

  // Pricing
  pricePerDay  Float
  pricePerHour Float?

  // Group info
  groupSize    Int           @default(1)

  // Media
  image        String?       // primary profile image
  images       String[]      // additional images
  videos       String[]      // video URLs

  // Contact
  phone        String?

  // Location
  location     String
  district     String
  state        String
  lat          Float?        // GPS latitude  (auto-filled from device on listing creation)
  lng          Float?        // GPS longitude

  // Availability window
  availableFrom DateTime?
  availableTo   DateTime?

  // Stats
  rating       Float         @default(0)
  ratingCount  Int           @default(0)

  available    Boolean       @default(true)
  status       ListingStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  bookings     Booking[]

  @@index([providerId])
  @@index([district])
  @@index([status])
  @@index([lat, lng])
  @@map("labour_listings")
}

model Booking {
  id                 String            @id @default(uuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  machineryListingId String?
  machineryListing   MachineryListing? @relation(fields: [machineryListingId], references: [id])
  labourListingId    String?
  labourListing      LabourListing?    @relation(fields: [labourListingId], references: [id])
  startDate          DateTime
  endDate            DateTime
  days               Int
  hours              Int?              // optional for hourly bookings
  workerCount        Int?              @default(1)
  totalAmount        Float
  status             BookingStatus     @default(PENDING)
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([machineryListingId])
  @@index([labourListingId])
  @@index([startDate, endDate])
  @@index([createdAt])
  @@map("bookings")
}

// ── Community Posts ───────────────────────────────────────────────────────────

model Post {
  id           String    @id @default(uuid())
  authorId     String
  author       User      @relation(fields: [authorId], references: [id])
  category     String
  title        String
  description  String
  images       String[]
  tags         String[]
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  viewCount    Int       @default(0)
  isPinned     Boolean   @default(false)
  scope        PostScope @default(ALL)
  district     String?
  city         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  likes        PostLike[]
  bookmarks    PostBookmark[]
  comments     Comment[]

  @@index([authorId])
  @@index([category])
  @@index([district])
  @@index([scope, district])
  @@index([createdAt])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
  @@map("post_likes")
}

model PostBookmark {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
  @@map("post_bookmarks")
}

model Comment {
  id        String    @id @default(uuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  parentId  String?
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  text      String
  likeCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  likes     CommentLike[]

  @@index([postId])
  @@index([postId, createdAt])
  @@index([authorId])
  @@map("comments")
}

model CommentLike {
  id        String  @id @default(uuid())
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("comment_likes")
}

// ── Community Groups (WhatsApp-like) ──────────────────────────────────────────

model Group {
  id            String   @id @default(uuid())
  name          String
  description   String?
  avatar        String?
  createdById   String
  createdBy     User     @relation("GroupsCreated", fields: [createdById], references: [id])
  district      String?
  city          String?
  isPublic      Boolean  @default(true)
  memberCount   Int      @default(1)
  lastMessage   String?
  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       GroupMember[]
  messages      GroupMessage[]

  @@index([district])
  @@index([createdById])
  @@map("groups")
}

model GroupMember {
  id       String    @id @default(uuid())
  groupId  String
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

model GroupMessage {
  id        String   @id @default(uuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("GroupMessagesSent", fields: [senderId], references: [id])
  text      String?
  imageUrl  String?
  type      String   @default("text") // text | image | system
  createdAt DateTime @default(now())

  @@index([groupId])
  @@index([groupId, createdAt])
  @@index([senderId])
  @@map("group_messages")
}

// ── Direct Messages ───────────────────────────────────────────────────────────

model DirectMessage {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("DMsSent", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("DMsReceived", fields: [receiverId], references: [id])
  text       String?
  imageUrl   String?
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
  @@index([receiverId, readAt])
  @@map("direct_messages")
}

// ── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, readAt])   // fast unread-count query
  @@index([userId, createdAt])
  @@map("notifications")
}

// ── AI Crop Disease Reports ───────────────────────────────────────────────────
// Every Krishi Raksha analysis is persisted so users can review history
// and so admin can audit / improve the AI model over time.

model CropDiseaseReport {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Input parameters
  pincode         String
  cropType        String
  growthStage     String
  variety         String?
  fieldArea       String?
  symptoms        String[] // array of symptom strings
  imageCount      Int      @default(0)

  // AI result summary (denormalised for fast list queries)
  overallRisk     Int      // 0–100
  riskLevel       String   // LOW | MODERATE | HIGH | CRITICAL
  primaryDisease  String
  confidenceScore Float
  diagnosisMethod String   @default("vision") // gemini-vision | claude-vision | multi-model-consensus | symptom-based
  modelAgreement  Boolean? // true = both models agreed

  // Full AI JSON response stored for detail view & audit
  fullReport      Json

  // Weather + soil snapshot at time of analysis
  weatherSnapshot Json?
  soilSnapshot    Json?

  // Linked scan chat session (farmer can ask follow-up questions)
  conversationId  String?
  conversation    AIConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())

  feedbacks       DiseaseFeedback[]

  @@index([userId])
  @@index([userId, createdAt])
  @@index([cropType])
  @@index([pincode])
  @@index([riskLevel])
  @@index([conversationId])
  @@map("crop_disease_reports")
}

// ── FarmMind AI Chat ──────────────────────────────────────────────────────────

model AIConversation {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String?       // auto-generated from first message
  summary      String?       @db.Text  // Claude-generated rolling summary (refreshed every 20 msgs)
  messageCount Int           @default(0)
  language     String        @default("en") // en | hi | mr | pa | te | ta | etc.
  isArchived   Boolean       @default(false)
  isScanSession Boolean      @default(false) // true = created from a crop scan
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     AIMessage[]
  voiceSessions VoiceSession[]
  scanReports  CropDiseaseReport[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@index([userId, isArchived])
  @@map("ai_conversations")
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String         // user | assistant
  content        String         @db.Text
  messageType    String         @default("text")  // text | diagnosis | market | scheme | voice
  structuredData Json?          // card data: diagnosis JSON, market prices, scheme info, etc.
  language       String         @default("en")
  tokensUsed     Int            @default(0)    // total tokens (input + output) for this exchange
  modelUsed      String?        // groq/llama-3.3-70b | claude-haiku | gemini-2.5-flash
  ragUsed        Boolean        @default(false)
  createdAt      DateTime       @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

// ── Daily Planner ─────────────────────────────────────────────────────────────

model PlannerTask {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  crop         String?
  field        String?
  priority     String    @default("today")   // urgent | today | plan
  icon         String?
  color        String?
  doneAt       DateTime?
  scheduledFor DateTime  @default(now())
  aiGenerated  Boolean   @default(false)
  aiReason     String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([userId, scheduledFor])
  @@map("planner_tasks")
}

// ── Disease Detection Feedback (Active Learning Loop) ─────────────────────────
// Every confirmed/corrected diagnosis improves future model accuracy.
// Weekly job: if new confirmed count > 500 → trigger model retraining pipeline.

model DiseaseFeedback {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportId         String
  report           CropDiseaseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  predictedDisease String            // what AI said
  confirmedDisease String?           // what farmer/expert said (null = farmer agreed)
  farmerAgreed     Boolean           // true = AI was correct
  confirmedBy      String            @default("farmer_self") // farmer_self | expert_kvk | agronomist
  expertNotes      String?           @db.Text
  usedForRetrain   Boolean           @default(false)         // flagged after being used in retraining batch

  createdAt        DateTime          @default(now())

  @@unique([userId, reportId]) // one feedback per report per user
  @@index([reportId])
  @@index([farmerAgreed])
  @@index([usedForRetrain])
  @@map("disease_feedback")
}

// ── Government Schemes (Sarkari Yojana) ──────────────────────────────────────
// Seeded weekly via cron from data.gov.in + manual entries.
// Claude AI answers eligibility questions using this data as context.

model GovernmentScheme {
  id              String              @id @default(uuid())
  schemeCode      String              @unique // e.g. "PM_KISAN", "PMFBY_MH"
  schemeName      String
  schemeNameHi    String?             // Hindi name
  schemeNameMr    String?             // Marathi name
  ministry        String?
  type            String              // central | state
  state           String?             // null = all India (central schemes)

  description     String              @db.Text
  benefitsSummary String
  eligibility     Json                // { landSizeMaxAcres, casteCategories[], incomeLimit, ageMin, ageMax, farmingTypes[] }
  documentsReq    String[]
  applicationUrl  String?
  helpline        String?

  benefitAmount   Float?              // INR amount per year / per event
  benefitType     String              // cash | subsidy | insurance | credit | training | equipment

  deadline        String?             // "31 March 2026" or null = ongoing
  isActive        Boolean             @default(true)

  // Full text stored for Claude RAG context
  fullText        String?             @db.Text

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  applications    SchemeApplication[]

  @@index([type])
  @@index([state])
  @@index([isActive])
  @@index([isActive, type])
  @@map("government_schemes")
}

model SchemeApplication {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  schemeId  String
  scheme    GovernmentScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  status    String           @default("interested") // interested | in_progress | submitted | approved | rejected
  notes     String?          @db.Text
  appliedAt DateTime?

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, schemeId]) // one tracking entry per farmer per scheme
  @@index([userId])
  @@index([userId, status])
  @@map("scheme_applications")
}

// ── Voice Sessions ────────────────────────────────────────────────────────────
// Scaffold for future Awaaz Saathi (voice assistant) feature.
// Stores transcription + TTS response metadata for each voice interaction.

model VoiceSession {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId   String?         // links to the AI chat conversation it created/continued
  conversation     AIConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  transcription    String?         @db.Text  // Whisper output
  transcriptionConf Float?                   // Whisper confidence 0-1
  responseText     String?         @db.Text  // Claude / LLM reply text
  audioInputUrl    String?         // S3 URL of farmer's voice recording
  audioOutputUrl   String?         // S3 URL of TTS audio (cached)

  languageDetected String?         // detected language code
  languageRequested String?        // farmer's profile language
  durationSeconds  Float?

  whisperModel     String?         // whisper-1 | etc.
  ttsVoice         String?         // Google TTS voice name used

  createdAt        DateTime        @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([conversationId])
  @@map("voice_sessions")
}

// ── Veterinary Doctors (पशु सेवा) ────────────────────────────────────────────
// Verified vets listed for farmer discovery. Farmers can call or WhatsApp.
// Seller App handles registration + document upload.
// Admin verifies before isListed = true.

model VeterinaryDoctor {
  id                 String    @id @default(uuid())

  // Basic info
  fullNameEn         String                          // "Dr. Ramesh Patil"
  fullNameMr         String                          // "डॉ. रमेश पाटील"
  phone              String    @unique
  altPhone           String?
  email              String?
  profilePhoto       String?                         // Cloudinary URL
  gender             String?                         // male | female | other
  dateOfBirth        DateTime?

  // Address
  addressLine1       String?
  village            String?
  taluka             String?
  district           String?
  state              String    @default("Maharashtra")
  pincode            String?

  // Geo (lat/lng stored flat for Prisma compatibility)
  latitude           Float?
  longitude          Float?

  // Professional
  registrationNumber String?   @unique
  councilName        String    @default("Maharashtra State Veterinary Council")
  experienceYears    Int       @default(0)
  qualifications     Json      @default("[]")        // [{degree,specialization,college,university,yearOfPassing}]

  // Practice
  practiceType       String    @default("clinic")    // clinic | mobile | both
  clinicName         String?
  clinicAddress      String?
  clinicPhotos       String[]  @default([])           // up to 5 Cloudinary URLs

  // Specializations & services (stored as string arrays)
  animalTypes        String[]  @default([])           // cow | buffalo | goat | ...
  services           String[]  @default([])           // general_checkup | vaccination | ...

  // Availability
  availableDays      String[]  @default([])           // mon | tue | ...
  startTime          String?                          // "09:00"
  endTime            String?                          // "18:00"
  emergencyAvailable Boolean   @default(false)

  // Fees
  consultationFee    Float?
  visitFee           Float?
  feeNoteEn          String?
  feeNoteMr          String?

  // Languages spoken
  languages          String[]  @default([])

  // Verification
  verificationStatus String    @default("draft")     // draft|pending|under_review|verified|rejected|suspended
  submittedAt        DateTime?
  rejectionReason    String?

  // Rating (denormalised for fast listing queries)
  ratingAverage      Float     @default(0)
  ratingCount        Int       @default(0)

  // Flags
  isActive           Boolean   @default(true)
  isListed           Boolean   @default(false)       // TRUE only when verified + active
  priority           Int       @default(0)            // admin-controlled sort boost

  // Engagement stats
  profileViews       Int       @default(0)
  callClicks         Int       @default(0)
  whatsappClicks     Int       @default(0)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  reviews            DoctorReview[]

  @@index([isListed, ratingAverage(sort: Desc)])
  @@index([isListed, district])
  @@index([verificationStatus])
  @@map("veterinary_doctors")
}

model DoctorReview {
  id          String           @id @default(uuid())
  doctorId    String
  doctor      VeterinaryDoctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  farmerName  String                                  // denormalised
  rating      Int                                     // 1–5
  comment     String?          @db.Text
  isVisible   Boolean          @default(true)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([doctorId, userId])                        // one review per farmer per doctor
  @@index([doctorId, createdAt(sort: Desc)])
  @@map("doctor_reviews")
}

// ── Weather Cache ─────────────────────────────────────────────────────────────
// Caches unified Open-Meteo + IMD weather responses.
// Cache key = lat/lon rounded to 2 decimal places (~1 km precision).
// TTL: 1 hour for forecast data, 30 min for IMD alerts (enforced in service).

model WeatherCache {
  id        String   @id @default(uuid())
  cacheKey  String   @unique  // "{lat}_{lon}" e.g. "18.52_73.86"
  data      Json              // full unified weather response
  cachedAt  DateTime @default(now())
  expiresAt DateTime          // cachedAt + 1h

  @@index([expiresAt])
  @@map("weather_cache")
}

// ════════════════════════════════════════════════════════════════════════════
// NEW AI SERVICES — Phase 1-4 additions
// ════════════════════════════════════════════════════════════════════════════

// ── Crop Master (ICAR reference data for 15+ Maharashtra crops) ───────────────
model CropMaster {
  id                 String   @id @default(uuid())
  name               String   @unique   // "soybean"
  nameHi             String             // "सोयाबीन"
  nameMr             String?            // "सोयाबीन"
  category           String             // cereal|pulse|oilseed|vegetable|fruit|spice|cash_crop|fodder
  seasons            String[]           // ["kharif"]
  maturityDays       Int      @default(120)
  varieties          Json     @default("[]")   // [{name, suitableRegions, maturityDays, yieldPerAcre}]
  seedRate           Json?              // {value, unit}  e.g. {value:30, unit:"kg/acre"}
  spacing            Json?              // {rowToRow:"30cm", plantToPlant:"5cm"}
  fertilizerSchedule Json     @default("[]")   // [{stage, stageDays, fertilizers:[{name,qty,unit}]}]
  irrigationSchedule Json     @default("[]")   // [{stage, criticalPeriod, waterReq, method}]
  commonPests        Json     @default("[]")   // [{pest, pestHi, season, solution}]
  commonDiseases     Json     @default("[]")   // [{disease, diseaseHi, symptoms, solution}]
  harvestIndicators  String[]
  mspCommodityCode   String?
  agmarknetCode      String?
  // FAO Kc coefficients for irrigation scheduling
  kcInitial          Float?   @default(0.4)
  kcMid              Float?   @default(1.0)
  kcLate             Float?   @default(0.6)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([category])
  @@map("crop_master")
}

// ── MSP Rates (CACP official prices) ─────────────────────────────────────────
model MSPRate {
  id                   String    @id @default(uuid())
  commodity            String
  commodityHi          String?
  season               String    // kharif | rabi
  year                 String    // "2025-26"
  mspPrice             Float     // ₹/quintal
  previousYearMSP      Float?
  increasePercent      Float?
  bonusIfAny           Float?
  procurementAgency    String?   // "NAFED" | "FCI" | "CCI"
  procurementStartDate DateTime?
  procurementEndDate   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([commodity, season, year])
  @@index([season, year])
  @@map("msp_rates")
}

// ── Mandi Prices (fetched from data.gov.in every 4 hours) ────────────────────
model MandiPrice {
  id           String   @id @default(uuid())
  commodity    String
  commodityHi  String?
  variety      String?
  market       String
  district     String
  state        String
  minPrice     Float              // ₹/quintal
  maxPrice     Float
  modalPrice   Float
  arrivalQty   Float?             // quintals arrived
  priceDate    DateTime
  source       String   @default("data.gov.in")
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime           // fetchedAt + 4h

  @@index([commodity, state, district])
  @@index([commodity, priceDate(sort: Desc)])
  @@index([expiresAt])
  @@map("mandi_prices")
}

// ── Price Alerts (farmer-set mandi price alerts) ──────────────────────────────
model PriceAlert {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commodity          String
  market             String?
  targetPrice        Float
  condition          String   // above | below
  isActive           Boolean  @default(true)
  triggeredAt        DateTime?
  notificationMethod String   @default("push")  // push | whatsapp | both
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([commodity, isActive])
  @@map("price_alerts")
}

// ── Soil Health Records ────────────────────────────────────────────────────────
model SoilHealthRecord {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fieldName       String?
  testDate        DateTime?
  sampleId        String?
  // Macro-nutrients (kg/ha unless noted)
  nitrogen        Float?
  phosphorus      Float?
  potassium       Float?
  ph              Float?
  ec              Float?             // dS/m
  organicCarbon   Float?             // %
  // Micro-nutrients (ppm)
  zinc            Float?
  iron            Float?
  manganese       Float?
  copper          Float?
  boron           Float?
  sulphur         Float?
  ratings         Json?              // {nitrogen:"low", phosphorus:"high", ...}
  recommendations Json?              // [{crop, fertilizers:[{name,qty,unit,stage}]}]
  inputMethod     String   @default("manual")   // manual | ocr_scan
  scanImageUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("soil_health_records")
}

// ── Pest Alerts (weather-triggered, generated by risk engine every 6h) ────────
model PestAlert {
  id              String   @id @default(uuid())
  pest            String
  pestHi          String?
  affectedCrops   String[]
  severity        String             // low | moderate | high | critical
  state           String
  districts       String[]
  lat             Float?
  lng             Float?
  radiusKm        Float?
  symptoms        Json     @default("[]")   // [{description, descriptionHi, imageUrl?}]
  solutions       Json     @default("{}")   // {organic:[...], chemical:[...]}
  triggerConditions Json?                   // {minHumidity, maxTemp, consecutiveRainDays, ...}
  validFrom       DateTime @default(now())
  validUntil      DateTime
  source          String   @default("auto")  // auto | NCIPM | KVK | admin
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([state, isActive])
  @@index([isActive, validUntil])
  @@map("pest_alerts")
}

// ── Crop Calendars (farmer-specific task schedule per crop) ───────────────────
model CropCalendar {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop         String
  season       String             // kharif | rabi | zaid
  year         String             // "2025"
  sowingDate   DateTime
  maturityDays Int                @default(120)
  state        String?
  district     String?
  fieldName    String?
  isActive     Boolean            @default(true)
  tasks        CropCalendarTask[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([userId, isActive])
  @@map("crop_calendars")
}

model CropCalendarTask {
  id              String       @id @default(uuid())
  calendarId      String
  calendar        CropCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  taskType        String       // land_preparation|sowing|fertilizer_basal|pest_spray_1|etc.
  title           String
  titleHi         String?
  description     String?      @db.Text
  descriptionHi   String?      @db.Text
  scheduledDate   DateTime
  windowStart     DateTime?
  windowEnd       DateTime?
  status          String       @default("upcoming") // upcoming|due|overdue|completed|skipped
  completedDate   DateTime?
  weatherAdjusted Boolean      @default(false)
  originalDate    DateTime?
  reminderSent    Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([calendarId, scheduledDate])
  @@index([status])
  @@map("crop_calendar_tasks")
}

// ── Irrigation Logs (daily ET0-based recommendations + farmer actions) ────────
model IrrigationLog {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop           String
  fieldName      String?
  date           DateTime @default(now())
  shouldIrrigate Boolean
  reason         String?
  reasonHi       String?
  waterAmount    String?  // "50mm"
  bestTime       String?  // "morning before 8 AM"
  temp           Float?
  humidity       Float?
  rainfall       Float?
  rainForecast   Float?   // next-3-day forecast sum
  windSpeed      Float?
  cropStage      String?
  etcValue       Float?   // crop evapotranspiration mm/day
  et0Value       Float?   // reference ET0
  kcValue        Float?   // crop coefficient used
  farmerAction   String?  // irrigated | skipped | pending
  createdAt      DateTime @default(now())

  @@index([userId, date(sort: Desc)])
  @@map("irrigation_logs")
}

// ── Feature Flags (per-service kill switch) ───────────────────────────────────
model FeatureFlag {
  id             String    @id @default(uuid())
  featureKey     String    @unique  // "mandi_bhav" | "pest_alerts" | etc.
  isEnabled      Boolean   @default(true)
  disabledReason String?
  disabledAt     DateTime?
  enabledAt      DateTime?
  updatedBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("feature_flags")
}

// ── API Health Logs (external API monitoring) ─────────────────────────────────
model APIHealthLog {
  id               String   @id @default(uuid())
  source           String   // agmarknet | open_meteo | data_gov_in | groq | gemini
  endpoint         String
  status           String   // success | failure | timeout | rate_limited
  responseTimeMs   Int?
  payloadSizeBytes Int?
  errorMessage     String?
  timestamp        DateTime @default(now())

  @@index([source, timestamp(sort: Desc)])
  @@index([timestamp])
  @@map("api_health_logs")
}

// ── AI Usage Tracking (per-user daily/monthly budget enforcement) ─────────────

model AIUsage {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date              // date portion only (YYYY-MM-DD)
  scanCount       Int      @default(0)           // number of crop scans today
  chatCount       Int      @default(0)           // number of AI chat messages today
  totalTokens     Int      @default(0)           // cumulative tokens used today
  totalCostUsd    Float    @default(0)           // cumulative cost today (USD)
  monthlyTokens   Int      @default(0)           // cumulative tokens this calendar month
  monthlyCostUsd  Float    @default(0)           // cumulative cost this month (USD)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date(sort: Desc)])
  @@map("ai_usage")
}
